<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IBM Dashboard Estratégico</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --bg: #0b1020;
      --panel: #121a33;
      --panel-soft: #182242;
      --text: #eef3ff;
      --muted: #9fb0d0;
      --line: rgba(255,255,255,.12);
      --accent: #5aa7ff;
      --good: #67e8a5;
      --warn: #ffd166;
      --bad: #ff6b6b;
      --purple: #b48cff;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, Segoe UI, Arial, sans-serif;
      background: radial-gradient(circle at top left, #1b2c5a 0%, var(--bg) 42%, #060913 100%);
      color: var(--text);
      min-height: 100vh;
    }

    header {
      padding: 36px 28px 20px;
      border-bottom: 1px solid var(--line);
      background: rgba(11,16,32,.72);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .topbar {
      max-width: 1280px;
      margin: auto;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 24px;
    }

    h1 {
      margin: 0 0 8px;
      font-size: clamp(28px, 4vw, 48px);
      letter-spacing: -1.4px;
    }

    .subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.5;
      max-width: 780px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255,255,255,.05);
      color: var(--muted);
      white-space: nowrap;
      font-size: 13px;
    }

    main {
      max-width: 1280px;
      margin: auto;
      padding: 28px;
    }

    .controls {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    button {
      border: 1px solid var(--line);
      background: rgba(255,255,255,.06);
      color: var(--text);
      padding: 10px 14px;
      border-radius: 12px;
      cursor: pointer;
      transition: .2s ease;
      font-weight: 600;
    }

    button:hover, button.active {
      background: var(--accent);
      color: #061024;
      border-color: var(--accent);
      transform: translateY(-1px);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 18px;
    }

    .card {
      background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.035));
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 20px;
      box-shadow: 0 24px 70px rgba(0,0,0,.22);
    }

    .span-3 { grid-column: span 3; }
    .span-4 { grid-column: span 4; }
    .span-5 { grid-column: span 5; }
    .span-6 { grid-column: span 6; }
    .span-7 { grid-column: span 7; }
    .span-8 { grid-column: span 8; }
    .span-12 { grid-column: span 12; }

    .metric-label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .metric-value {
      font-size: 30px;
      font-weight: 800;
      letter-spacing: -1px;
    }

    .metric-note {
      margin-top: 8px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.4;
    }

    h2, h3 {
      margin: 0 0 14px;
      letter-spacing: -.5px;
    }

    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 760px;
    }

    th, td {
      padding: 13px 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      font-size: 14px;
    }

    th {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .7px;
    }

    .pill {
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      display: inline-block;
    }

    .good { background: rgba(103,232,165,.15); color: var(--good); }
    .warn { background: rgba(255,209,102,.15); color: var(--warn); }
    .bad { background: rgba(255,107,107,.15); color: var(--bad); }
    .purple { background: rgba(180,140,255,.15); color: var(--purple); }

    .insight {
      font-size: 15px;
      line-height: 1.65;
      color: #dbe6ff;
    }

    .insight strong { color: white; }

    .segment-card {
      cursor: pointer;
      transition: .2s ease;
    }

    .segment-card:hover {
      transform: translateY(-3px);
      border-color: rgba(90,167,255,.7);
    }

    .bar {
      height: 9px;
      border-radius: 99px;
      background: rgba(255,255,255,.10);
      overflow: hidden;
      margin-top: 12px;
    }

    .bar > div {
      height: 100%;
      border-radius: 99px;
      background: linear-gradient(90deg, var(--accent), var(--purple));
    }

    .hidden { display: none; }

    footer {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
      padding: 20px 28px 40px;
      max-width: 1280px;
      margin: auto;
    }

    @media (max-width: 900px) {
      .span-3, .span-4, .span-5, .span-6, .span-7, .span-8 { grid-column: span 12; }
      .topbar { flex-direction: column; }
      header { position: static; }
    }
  </style>
</head>
<body>
  <header>
    <div class="topbar">
      <div>
        <h1>IBM Dashboard Estratégico</h1>
        <p class="subtitle">Análise interativa da IBM por segmento: receita, lucratividade, contribuição econômica, complexidade, assimetria e opcionalidades. Base aproximada: FY2025 e Q1 2026 divulgados pela companhia.</p>
      </div>
      <div class="badge">◈ IBM: software + mainframe + IA + quantum</div>
    </div>
  </header>

  <main>
    <section class="controls">
      <button class="active" onclick="setView('overview', this)">Visão Geral</button>
      <button onclick="setView('segments', this)">Segmentos</button>
      <button onclick="setView('optionality', this)">Opcionalidades</button>
      <button onclick="setView('risks', this)">Riscos</button>
    </section>

    <section id="overview" class="view">
      <div class="grid">
        <div class="card span-3">
          <div class="metric-label">Receita FY2025</div>
          <div class="metric-value">US$ 67,5 bi</div>
          <div class="metric-note">IBM é grande, madura e ainda relevante em infraestrutura crítica corporativa.</div>
        </div>
        <div class="card span-3">
          <div class="metric-label">Maior motor econômico</div>
          <div class="metric-value">Software</div>
          <div class="metric-note">Aprox. 44% da receita e mais de 60% do lucro de segmento.</div>
        </div>
        <div class="card span-3">
          <div class="metric-label">Parte mais resiliente</div>
          <div class="metric-value">IBM Z</div>
          <div class="metric-note">Mainframes seguem críticos para bancos, governos e seguradoras.</div>
        </div>
        <div class="card span-3">
          <div class="metric-label">Maior convexidade</div>
          <div class="metric-value">Quantum</div>
          <div class="metric-note">Ainda é opção de longo prazo, não lucro operacional atual.</div>
        </div>

        <div class="card span-7">
          <h2>Receita por segmento</h2>
          <canvas id="revenueChart" height="120"></canvas>
        </div>
        <div class="card span-5">
          <h2>Lucro de segmento</h2>
          <canvas id="profitChart" height="120"></canvas>
        </div>

        <div class="card span-12">
          <h2>Resumo Morgana</h2>
          <p class="insight"><strong>A IBM não é mais uma empresa de computador velho.</strong> Ela virou uma combinação de software enterprise de alta margem, consultoria de implementação, infraestrutura crítica e uma opção tecnológica/geopolítica em IA e computação quântica. A parte boa é que o downside é protegido por clientes institucionais e sistemas difíceis de trocar. A parte perigosa é que o mercado pode pagar caro demais por optionality que ainda não virou caixa.</p>
        </div>
      </div>
    </section>

    <section id="segments" class="view hidden">
      <div class="grid">
        <div class="card span-12">
          <h2>Segmentos da IBM</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Segmento</th>
                  <th>O que faz</th>
                  <th>Receita 2025</th>
                  <th>% Receita</th>
                  <th>Margem segmento</th>
                  <th>Lucro segmento</th>
                  <th>Leitura</th>
                </tr>
              </thead>
              <tbody id="segmentTable"></tbody>
            </table>
          </div>
        </div>

        <div class="card span-3 segment-card" onclick="selectSegment('Software')">
          <h3>Software</h3>
          <div class="metric-value">44%</div>
          <div class="metric-note">Cérebro econômico da IBM</div>
          <div class="bar"><div style="width: 44%"></div></div>
        </div>
        <div class="card span-3 segment-card" onclick="selectSegment('Consulting')">
          <h3>Consulting</h3>
          <div class="metric-value">31%</div>
          <div class="metric-note">Implantação, projetos e transformação</div>
          <div class="bar"><div style="width: 31%"></div></div>
        </div>
        <div class="card span-3 segment-card" onclick="selectSegment('Infrastructure')">
          <h3>Infrastructure</h3>
          <div class="metric-value">23%</div>
          <div class="metric-note">Máquinas críticas, IBM Z e storage</div>
          <div class="bar"><div style="width: 23%"></div></div>
        </div>
        <div class="card span-3 segment-card" onclick="selectSegment('Financing')">
          <h3>Financing</h3>
          <div class="metric-value">1%</div>
          <div class="metric-note">Financiamento para clientes</div>
          <div class="bar"><div style="width: 1%"></div></div>
        </div>

        <div class="card span-12">
          <h2 id="selectedTitle">Clique em um segmento</h2>
          <p id="selectedText" class="insight">Escolha Software, Consulting, Infrastructure ou Financing para ver a explicação estratégica.</p>
        </div>
      </div>
    </section>

    <section id="optionality" class="view hidden">
      <div class="grid">
        <div class="card span-6">
          <h2>Mapa de opcionalidade</h2>
          <canvas id="optionalityChart" height="160"></canvas>
        </div>
        <div class="card span-6">
          <h2>Onde está a assimetria?</h2>
          <p class="insight"><strong>1. Software/Red Hat:</strong> optionality mais monetizável hoje. Hybrid cloud, dados, automação e IA corporativa.</p>
          <p class="insight"><strong>2. IBM Z:</strong> menos sexy, mas com lock-in brutal. Bancos e governos não substituem core systems do dia para a noite.</p>
          <p class="insight"><strong>3. Quantum:</strong> maior convexidade, mas maior incerteza. É uma opção tecnológica e geopolítica de longo prazo.</p>
        </div>
        <div class="card span-12">
          <h2>Ranking de opcionalidades</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Opcionalidade</th>
                  <th>Prazo</th>
                  <th>Probabilidade</th>
                  <th>Impacto se der certo</th>
                  <th>Comentário</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>IA corporativa</td><td>Curto/médio</td><td><span class="pill good">Alta</span></td><td>Alto</td><td>Mais próxima de virar receita real.</td></tr>
                <tr><td>Red Hat / Hybrid Cloud</td><td>Curto/médio</td><td><span class="pill good">Alta</span></td><td>Alto</td><td>Ajuda empresas que não querem depender de uma única nuvem pública.</td></tr>
                <tr><td>Automation/Data</td><td>Curto</td><td><span class="pill good">Alta</span></td><td>Médio/alto</td><td>Produto vendável, prático e com margem.</td></tr>
                <tr><td>IBM Z com IA</td><td>Médio</td><td><span class="pill warn">Média</span></td><td>Médio/alto</td><td>Modernização sem trocar o motor inteiro.</td></tr>
                <tr><td>Quantum / Anderon</td><td>Longo</td><td><span class="pill purple">Incerta</span></td><td>Muito alto</td><td>Não é caixa agora. É call option estratégica.</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <section id="risks" class="view hidden">
      <div class="grid">
        <div class="card span-4">
          <h2>Risco 1</h2>
          <div class="metric-value">Consulting</div>
          <p class="insight">Grande demais, margem menor e crescimento menos escalável. Pode diluir a narrativa de empresa de software.</p>
        </div>
        <div class="card span-4">
          <h2>Risco 2</h2>
          <div class="metric-value">Valuation</div>
          <p class="insight">Se o mercado pagar como growth puro, a tese fica perigosa. IBM ainda é empresa madura.</p>
        </div>
        <div class="card span-4">
          <h2>Risco 3</h2>
          <div class="metric-value">Quantum hype</div>
          <p class="insight">Quantum pode ser enorme, mas pode demorar muito. O erro é tratar opção como lucro certo.</p>
        </div>
        <div class="card span-12">
          <h2>Diagnóstico final</h2>
          <p class="insight">A IBM é uma tese de <strong>base defensiva com opções tecnológicas embutidas</strong>. A base vem de Software, IBM Z e clientes institucionais. A convexidade vem de IA corporativa, Red Hat, automação e quantum. A pergunta certa não é “IBM é uma nova Nvidia?”. Não é. A pergunta certa é: <strong>quanto o mercado está pagando por uma empresa madura que carrega optionality real escondida?</strong></p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    Dados aproximados com base em divulgações públicas recentes da IBM. Dashboard educacional/analítico, não recomendação de investimento.
  </footer>

  <script>
    const segments = [
      {
        name: 'Software', revenue: 30.0, revenuePct: 44, margin: 33.1, profit: 9.9,
        role: 'Programas, plataformas, Red Hat, IA, dados, automação e hybrid cloud.',
        reading: 'Motor nobre', tag: 'good',
        detail: 'Software é o cérebro econômico da IBM. Aqui ficam Red Hat, dados, automação, IA corporativa e ferramentas usadas por grandes empresas. É o segmento mais importante porque tem margem alta, recorrência e maior capacidade de re-rating.'
      },
      {
        name: 'Consulting', revenue: 21.1, revenuePct: 31, margin: 11.7, profit: 2.5,
        role: 'Consultoria, implementação, integração de sistemas, transformação digital e IA.',
        reading: 'Útil, mas menos escalável', tag: 'warn',
        detail: 'Consulting funciona como braço de implantação. Ajuda clientes a usar IA, nuvem e modernização. O problema é que depende mais de pessoas, cresce menos e tem margem menor. É canal de venda, mas não é a joia econômica.'
      },
      {
        name: 'Infrastructure', revenue: 15.7, revenuePct: 23, margin: 22.0, profit: 3.5,
        role: 'Mainframes IBM Z, servidores, storage e infraestrutura crítica.',
        reading: 'Subestimado', tag: 'purple',
        detail: 'Infrastructure parece velho, mas é poderoso. IBM Z roda sistemas críticos de bancos, seguradoras e governos. É difícil substituir. O valor está no lock-in, na confiabilidade e no ciclo de atualização dos mainframes.'
      },
      {
        name: 'Financing', revenue: 0.7, revenuePct: 1, margin: 70.7, profit: 0.5,
        role: 'Financiamento, leasing e crédito para clientes comprarem soluções IBM.',
        reading: 'Pequeno suporte', tag: 'bad',
        detail: 'Financing é pequeno em receita, mas ajuda a fechar contratos grandes. É quase um mini-banco interno para clientes comprarem tecnologia IBM.'
      }
    ];

    function setView(id, btn) {
      document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));
      document.getElementById(id).classList.remove('hidden');
      document.querySelectorAll('button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    }

    function renderTable() {
      const tbody = document.getElementById('segmentTable');
      tbody.innerHTML = segments.map(s => `
        <tr>
          <td><strong>${s.name}</strong></td>
          <td>${s.role}</td>
          <td>US$ ${s.revenue.toFixed(1)} bi</td>
          <td>${s.revenuePct}%</td>
          <td>${s.margin}%</td>
          <td>US$ ${s.profit.toFixed(1)} bi</td>
          <td><span class="pill ${s.tag}">${s.reading}</span></td>
        </tr>
      `).join('');
    }

    function selectSegment(name) {
      const s = segments.find(x => x.name === name);
      document.getElementById('selectedTitle').textContent = s.name + ' — leitura estratégica';
      document.getElementById('selectedText').textContent = s.detail;
    }

    function createCharts() {
      const commonOptions = {
        plugins: { legend: { labels: { color: '#dbe6ff' } } },
        scales: {
          x: { ticks: { color: '#9fb0d0' }, grid: { color: 'rgba(255,255,255,.08)' } },
          y: { ticks: { color: '#9fb0d0' }, grid: { color: 'rgba(255,255,255,.08)' } }
        }
      };

      new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
          labels: segments.map(s => s.name),
          datasets: [{ label: 'Receita 2025 — US$ bi', data: segments.map(s => s.revenue), borderWidth: 1 }]
        },
        options: commonOptions
      });

      new Chart(document.getElementById('profitChart'), {
        type: 'doughnut',
        data: {
          labels: segments.map(s => s.name),
          datasets: [{ label: 'Lucro de segmento', data: segments.map(s => s.profit) }]
        },
        options: { plugins: { legend: { labels: { color: '#dbe6ff' } } } }
      });

      new Chart(document.getElementById('optionalityChart'), {
        type: 'radar',
        data: {
          labels: ['Monetização', 'Margem', 'Defensividade', 'Convexidade', 'Incerteza invertida'],
          datasets: [
            { label: 'Software/Red Hat', data: [9, 9, 8, 7, 8] },
            { label: 'IBM Z', data: [7, 7, 9, 5, 9] },
            { label: 'Quantum', data: [2, 4, 3, 10, 2] }
          ]
        },
        options: {
          plugins: { legend: { labels: { color: '#dbe6ff' } } },
          scales: { r: { ticks: { color: '#9fb0d0', backdropColor: 'transparent' }, grid: { color: 'rgba(255,255,255,.12)' }, pointLabels: { color: '#dbe6ff' } } }
        }
      });
    }

    renderTable();
    createCharts();
  </script>
</body>
</html>
